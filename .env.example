# MongoDB Atlas connection string
# Get this from: Atlas > Cluster > Connect > Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mappyhour?retryWrites=true&w=majority

# Password for the admin dashboard (x-admin-token header)
ADMIN_PASSWORD=choose_a_strong_password_here

# Port (optional, defaults to 3000)
PORT=3000

